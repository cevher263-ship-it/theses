{
  "manifest_version": 3,
  "name": "YÖK Tez Merkezi Veri İndirme Aracı",
  "description": "YÖK Ulusal Tez Merkezi'nden tez metaverilerini (Excel/CSV/RIS/BibTeX) ve PDF metinlerini toplu indirir. Yeni arayüz uyumlu.",
  "author": "Muhammet Yunus Tunca (orijinal) - yeni arayüz uyarlaması",
  "version": "1.10.0",
  "action": {
    "default_title": "Tez Verilerini İndir",
    "default_icon": "yok-logo.png"
  },
  "icons": { "128": "yok-logo.png" },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://tez.yok.gov.tr/*"],
  "background": { "service_worker": "background.js" },
  "web_accessible_resources": [
    {
      "resources": [
        "yoktez-veri-indir.js",
        "lib/xlsx.bundle.js",
        "lib/jszip.min.js",
        "lib/FileSaver.min.js"
      ],
      "matches": ["https://tez.yok.gov.tr/*"]
    }
  ]
}
